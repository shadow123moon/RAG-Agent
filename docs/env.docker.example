# 复制为项目根目录 `.env` 使用：
# PowerShell: Copy-Item docs\env.docker.example .env

SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:13306/PaiSmart?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:29092
SPRING_KAFKA_TOPIC_PARTITIONS=1
SPRING_KAFKA_TOPIC_REPLICATION_FACTOR=1
SPRING_KAFKA_TOPIC_RAG_INGEST=rag-ingest-topic
SPRING_KAFKA_TOPIC_RAG_DLT=rag-ingest-dlt

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=uploads

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=19200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me
ELASTICSEARCH_INSECURE_TRUST_ALL_CERTIFICATES=false
ELASTICSEARCH_INIT_ENABLE=true

# JWT
JWT_SECRET_KEY=XeJw0yUoFDJWSNbWYFVEIXGfO8XgHrQLrIkKci5J9eA=

# 本地开发建议直接创建管理员，便于进入后台功能
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=LocalDevAdmin123!
ADMIN_BOOTSTRAP_PRIMARY_ORG=default
ADMIN_BOOTSTRAP_ORG_TAGS=default,admin

# 本地开发建议开放注册，减少邀请码干扰
APP_AUTH_REGISTRATION_MODE=OPEN
APP_AUTH_INVITE_REQUIRED=false

SECURITY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# 如果暂时没有大模型 / Embedding Key，可以先保持为空。
# 同时把启动知识库导入关掉，避免启动阶段触发向量化。
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
EMBEDDING_API_KEY=
EMBEDDING_ALLOW_LOCAL_FALLBACK=false
RAG_PYTHON_BASE_URL=http://localhost:18080
RAG_PYTHON_INTERNAL_TOKEN=change-me
RAG_PYTHON_QUERY_PATH=/internal/v1/query
RAG_QUERY_DEFAULT_TOP_K=8
RAG_QUERY_MAX_TOP_K=30
RAG_CALLBACK_TOKEN=change-me
RAG_LEGACY_CONSUMER_ENABLED=false
RAG_JAVA_CALLBACK_BASE_URL=http://localhost:8081
RAG_JAVA_CALLBACK_PATH=/api/v1/internal/rag/callback/ingest
RAG_KAFKA_GROUP_ID=rag-python-ingest-group
RAG_KAFKA_MAX_RETRIES=3
KNOWLEDGE_BOOTSTRAP_ENABLED=false

LOG_LEVEL_APP=INFO

WX_PAY_ENABLE=false
